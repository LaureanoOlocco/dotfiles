return {
  "willothy/nvim-cokeline",
  dependencies = {
    "nvim-lua/plenary.nvim",
    "nvim-tree/nvim-web-devicons",
  },
  event = "VeryLazy",
  config = function()
    local get_hex = require("cokeline.hlgroups").get_hl_attr
    local palette = {
      base = {
        bg_hi = "#242424",
        bg_alt = "#141414",
        fg = "#D4D4D4",
        comment = "#7D7D7D",
        link = "#81A1C1",
        git_modified = "#F1B467",
        error = "#F14C4C",
        warn = "#F8C762",
      },
    }

    local active_bg = palette.base.bg_hi
    local inactive_bg = palette.base.bg_alt
    local active_fg = get_hex("Normal", "fg") or palette.base.fg
    local inactive_fg = get_hex("Comment", "fg") or palette.base.comment

    require("cokeline").setup({
      show_if_buffers_are_at_least = 2,

      sidebar = {
        filetype = { "neo-tree" },
        components = {
          {
            text = function()
              return "  Files"
            end,
            bold = true,
            fg = active_fg,
            bg = inactive_bg,
          },
        },
      },

      default_hl = {
        fg = function(buffer)
          return buffer.is_focused and active_fg or inactive_fg
        end,
        bg = function(buffer)
          return buffer.is_focused and active_bg or inactive_bg
        end,
      },

      components = {
        {
          text = function(buffer)
            return buffer.is_focused and "▎" or " "
          end,
          fg = function(buffer)
            return buffer.is_focused and palette.base.link or nil
          end,
        },
       -- { text = " " },
        {
          text = function(buffer) return buffer.devicon.icon end,
          fg = function(buffer)
            return buffer.is_focused and buffer.devicon.color or inactive_fg
          end,
        },
       -- { text = " " },
        {
          text = function(buffer) return buffer.filename end,
          bold = function(buffer) return buffer.is_focused end,
        },
        { text = " " },
        {
          text = function(buffer)
            return buffer.is_modified and "● " or ""
          end,
          fg = function(buffer)
            return buffer.is_modified and palette.base.git_modified or nil
          end,
        },
        {
          text = function(buffer)
            local errors = buffer.diagnostics.errors
            local warnings = buffer.diagnostics.warnings
            local result = ""
            if errors > 0 then result = result .. " " end
            if warnings > 0 then result = result .. " " end
            return result
          end,
          fg = function(buffer)
            if buffer.diagnostics.errors > 0 then
              return palette.base.error
            elseif buffer.diagnostics.warnings > 0 then
              return palette.base.warn
            end
          end,
        },
        { text = " " },
      },
    })

    vim.keymap.set("n", "<Tab>", "<Plug>(cokeline-focus-next)", { silent = true })
    vim.keymap.set("n", "<S-Tab>", "<Plug>(cokeline-focus-prev)", { silent = true })
  end,
}
