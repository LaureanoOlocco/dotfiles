[
  {
    "context": "Workspace",
    "bindings": {
      "alt-left": "pane::ActivatePreviousItem",
      "alt-right": "pane::ActivateNextItem",
      "alt-c": "pane::CloseActiveItem",
      "alt-q": "zed::Quit",
      "alt-e": "project_panel::ToggleFocus",
      "alt-f": "file_finder::Toggle",
      "alt-w": "pane::DeploySearch",
      "alt-[": "multi_workspace::ToggleWorkspaceSidebar",
      "alt-p": "workspace::ToggleRightDock",
      "alt-g g": "git_panel::ToggleFocus",
      "alt-g p": "git::Push",
      "ctrl-p": null,
      "ctrl-shift-c": null,
      "ctrl-shift-g": null,
      "ctrl-alt-b": null,
      "ctrl-~": null,
      "f7": "terminal_panel::ToggleFocus"
    }
  },
  {
    "context": "Terminal",
    "bindings": {
      "f7": "workspace::ToggleBottomDock"
    }
  },
  {
    "context": "GitPanel",
    "bindings": {
      "alt-g g": "workspace::ToggleLeftDock",
      "alt-g p": "git::Push"
    }
  },
  {
    "context": "ProjectPanel",
    "bindings": {
      "alt-e": "workspace::ToggleLeftDock"
    }
  },
  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      "space": "project_panel::Open"
    }
  },
  {
    "context": "BufferSearchBar",
    "bindings": {
      "escape": "buffer_search::Dismiss"
    }
  },
  {
    "context": "BufferSearchBar > Editor",
    "bindings": {
      "escape": "buffer_search::Dismiss"
    }
  },
  {
    "context": "Editor && vim_mode == normal",
    "bindings": {
      "tab": "tab_switcher::Toggle",
      "shift-tab": ["tab_switcher::Toggle", { "select_last": true }],
      "ctrl-alt-k": "editor::AddSelectionAbove",
      "ctrl-alt-j": "editor::AddSelectionBelow"
    }
  },
  {
    "context": "Editor && showing_completions",
    "bindings": {
      "alt-l": "editor::ConfirmCompletion"
    }
  },
  {
    "context": "Editor && edit_prediction",
    "bindings": {
      "alt-[": "multi_workspace::ToggleWorkspaceSidebar",
      "alt-l": "editor::AcceptEditPrediction"
    }
  }
]
