// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "cli_default_open_behavior": "existing_window",
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "agent_servers": {
    "claude-acp": {
      "default_config_options": {
        "mode": "plan",
        "model": "haiku"
      },
      "favorite_config_option_values": {
        "mode": [
          "plan"
        ]
      },
      "type": "registry"
    }
  },
  "edit_predictions": {
    "enabled_in_text_threads": true
  },
  "format_on_save": "off",
  "agent": {
    "dock": "right",
    "default_profile": "ask",
    "tool_permissions": {
      "tools": {
        "move_path": {
          "default": "allow"
        },
        "terminal": {
          "default": "allow"
        }
      }
    },
    "default_model": {
      "enable_thinking": false,
      "provider": "openai",
      "model": "gpt-5.5"
    },
    "favorite_models": [
      {
        "provider": "openai",
        "model": "gpt-5.4",
        "enable_thinking": false
      },
      {
        "provider": "anthropic",
        "model": "claude-opus-4-6-latest",
        "enable_thinking": false
      },
      {
        "provider": "anthropic",
        "model": "claude-sonnet-4-6-latest",
        "enable_thinking": false
      },
      {
        "provider": "zed.dev",
        "model": "claude-sonnet-4-6",
        "enable_thinking": false
      }
    ],
    "model_parameters": []
  },
  "icon_theme": "Flow Dawn Light",
  "vim_mode": true,
  "terminal": {
    "font_size": 17.0,
    "font_family": "JetBrainsMono Nerd Font",
    "env": {
      "ZELLIJ_AUTO_START": "false"
    }
  },
  "minimap": {
    "show": "never"
  },
  "buffer_font_family": "CaskaydiaCove Nerd Font Mono",
  "tab_size": 5,
  "base_keymap": "VSCode",
  "ui_font_size": 17,
  "buffer_font_size": 18,
  "agent_ui_font_size": 22,
  "agent_buffer_font_size": 17,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Cursor Dark",
  },
}
